{
  "name": "elpais-news-intelligence-platform",
  "version": "1.0.0",
  "description": "Production-style Node.js platform for scraping, analyzing, and serving El Pais opinion articles",
  "main": "api/server.js",
  "scripts": {
    "start": "node api/server.js",
    "start:api": "node api/server.js",
    "start:scheduler": "node scraper/schedular.js",
    "start:all": "concurrently \"node api/server.js\" \"node scraper/schedular.js\"",
    "scrape": "node scraper/scraper.js",
    "test:browserstack": "mocha tests/browserstackTests.js --timeout 300000"
  },
  "dependencies": {
    "axios": "^1.8.2",
    "cheerio": "1.0.0-rc.12",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "8.11.0",
    "morgan": "^1.10.0",
    "natural": "6.10.5",
    "node-cron": "^4.0.5",
    "selenium-webdriver": "^4.29.0",
    "sentiment": "^5.0.2",
    "translate": "^3.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "mocha": "^11.1.0"
  },
  "engines": {
    "node": ">=20.15.0"
  }
}
